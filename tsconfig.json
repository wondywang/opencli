{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "incremental": true
  },
  "include": [
    "src/**/*.ts",
    "clis/**/*.ts",
    "registry.ts",
    "errors.ts",
    "types.ts",
    "utils.ts",
    "logger.ts",
    "launcher.ts",
    "browser/**/*.ts",
    "download/**/*.ts",
    "pipeline/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "extension"]
}
